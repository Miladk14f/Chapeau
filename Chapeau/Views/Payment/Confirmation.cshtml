@using Chapeau.Models.Enums
@model Chapeau.ViewModels.PaymentConfirmationViewModel
@{
    ViewData["Title"] = "Payment confirmation";
    decimal total = Model.Items.Sum(i => i.Price * i.Qty) + Model.Tip;

    var receipt = new Chapeau.ViewModels.BillReceiptViewModel
    {
        Items = Model.Items,
        Tip = Model.Tip,
        Date = Model.PaidAt,
        TableId = Model.TableId,
        Guests = Model.Guests,
        Interactive = false
    };
    string MethodLabel(PaymentMethod m) => m switch
    {
        PaymentMethod.Cash => "💵 Cash",
        PaymentMethod.CreditCard => "💳 Credit card",
        PaymentMethod.DebitCard => "💳 Debit card",
        _ => m.ToString()
    };
}

<div class="bill-wrap">
    <div class="bill-header">
        <div class="bill-header-left">
            <a class="back-btn" asp-controller="RestaurantTable" asp-action="Index">‹</a>
            <div>
                <div class="bill-title">Payment confirmed — Table @Model.TableId</div>
                <div class="bill-sub">@Model.Guests guests · @Model.WaiterName</div>
            </div>
        </div>
        <div class="bill-actions">
            <button type="button" class="btn-print-icon" onclick="window.print()">🖨</button>
        </div>
    </div>

    <div class="pay-confirm-banner">
        ✓ Paid — €@total.ToString("0.00") @(Model.IsSplit ? "· split" : "")
        <div class="pay-confirm-sub">@Model.PaidAt.ToString("dddd, d MMMM yyyy · HH:mm")</div>
    </div>

    <partial name="_BillReceipt" model="receipt" />

    @if (Model.Payments.Any())
    {
        <div class="receipt">
            <div class="vat-section" style="padding:16px 24px">
                <div class="vat-section-title">Payments</div>
                @foreach (var p in Model.Payments)
                {
                    <div class="item-line">
                        <div><div class="item-line-left">@MethodLabel(p.PaymentMethod)</div></div>
                        <div class="item-line-price">€@p.Amount.ToString("0.00")</div>
                    </div>
                }
            </div>
        </div>
    }

    <div class="confirm-actions">
        <button type="button" class="cf-btn cf-btn-print" onclick="window.print()">🖨 Print receipt</button>
        <form method="post" asp-action="CloseTable" class="cf-form">
            <input type="hidden" name="tableId" value="@Model.TableId" />
            <input type="hidden" name="orderId" value="@Model.OrderId" />
            <button type="submit" class="cf-btn cf-btn-close">✓ End &amp; close table</button>
        </form>
        <a class="cf-btn cf-btn-back" asp-controller="RestaurantTable" asp-action="Index">‹ Back to tables · keep open</a>
    </div>
</div>
