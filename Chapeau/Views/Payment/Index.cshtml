@model Chapeau.ViewModels.BillViewModel
@{
    ViewData["Title"] = "Bill";
    // flatten items by qty for by-item split
    var flatItems = Model.Items9.Concat(Model.Items21)
        .SelectMany(i => Enumerable.Repeat(i, i.Qty))
        .ToList();
}

<div class="bill-wrap">
    <div class="bill-header">
        <div class="bill-header-left">
            <a class="back-btn" asp-controller="RestaurantTable" asp-action="Index">‹</a>
            <div>
                <div class="bill-title">Bill — Table @Model.TableId</div>
                <div class="bill-sub">@Model.Guests guests · @Model.WaiterName</div>
            </div>
        </div>
        <div class="bill-actions">
            <button type="button" class="btn-split" onclick="openSplit()">⋈ Split bill</button>
            <button type="button" class="btn-print-icon" onclick="window.print()">🖨</button>
        </div>
    </div>

    <!-- Receipt -->
    <div class="receipt">
        <div class="receipt-head">
            <h2>Restaurant Chapeau</h2>
            <p>Centrum, Zeewolde · Tel: (036) 522 1234</p>
            <div class="receipt-date">
                @Model.GeneratedAt.ToString("dddd, d MMMM yyyy") · @Model.GeneratedAt.ToString("HH:mm")<br />
                Table @Model.TableId · @Model.Guests guests
            </div>
        </div>
        <div class="receipt-body">
            @if (Model.Items9.Any())
            {
                <div class="vat-section">
                    <div class="vat-section-title">Food &amp; Soft Drinks · 9% VAT</div>
                    @foreach (var item in Model.Items9)
                    {
                        <div class="item-line">
                            <div>
                                <div class="item-line-left">@item.Qty× @item.Name</div>
                                @if (!string.IsNullOrEmpty(item.StaffName))
                                {
                                    <div class="item-line-by">By: @item.StaffName</div>
                                }
                            </div>
                            <div class="item-line-price">€@item.LineTotal.ToString("0.00")</div>
                        </div>
                    }
                    <div class="vat-line"><span>Excl. VAT</span><span>€@Model.Excl9.ToString("0.00")</span></div>
                    <div class="vat-line"><span>VAT 9%</span><span>€@Model.Vat9Amount.ToString("0.00")</span></div>
                </div>
            }
            @if (Model.Items21.Any())
            {
                <div class="vat-section">
                    <div class="vat-section-title">Alcoholic Beverages · 21% VAT</div>
                    @foreach (var item in Model.Items21)
                    {
                        <div class="item-line">
                            <div>
                                <div class="item-line-left">@item.Qty× @item.Name</div>
                                @if (!string.IsNullOrEmpty(item.StaffName))
                                {
                                    <div class="item-line-by">By: @item.StaffName</div>
                                }
                            </div>
                            <div class="item-line-price">€@item.LineTotal.ToString("0.00")</div>
                        </div>
                    }
                    <div class="vat-line"><span>Excl. VAT</span><span>€@Model.Excl21.ToString("0.00")</span></div>
                    <div class="vat-line"><span>VAT 21%</span><span>€@Model.Vat21Amount.ToString("0.00")</span></div>
                </div>
            }
        </div>
        <div class="receipt-totals">
            <div class="total-line">
                <span>Subtotal (incl. VAT)</span><span>€@Model.Subtotal.ToString("0.00")</span>
            </div>
            <div class="total-line detail">
                <span>incl. VAT 9%: €@Model.Vat9Amount.ToString("0.00") · VAT 21%: €@Model.Vat21Amount.ToString("0.00")</span>
                <span>€@Model.TotalVat.ToString("0.00")</span>
            </div>
            <div class="total-line grand">
                <span>Total to pay</span><span class="price">€@Model.TotalToPay.ToString("0.00")</span>
            </div>
        </div>
        <div class="receipt-footer">
            <div class="vat-info">VAT no: NL123456789B01 · KvK: 12345678</div>
            <div class="merci">Merci et à bientôt!</div>
        </div>
    </div>

    <!-- Payment form -->
    <form method="post" asp-action="Process" id="payForm">
        <input type="hidden" name="tableId" value="@Model.TableId" />
        <input type="hidden" name="orderId" value="@Model.OrderId" />
        <input type="hidden" name="splitWays" value="1" id="splitWaysInput" />
        <input type="hidden" name="splitMethod" value="none" />

        <!-- Tip -->
        <div class="section-card">
            <div class="section-title">Tip (optional)</div>
            <div class="tip-pills">
                @foreach (var t in new[] { ("0", "None"), ("1", "€1"), ("2", "€2"), ("5", "€5"), ("10", "€10") })
                {
                    <input class="tip-radio" type="radio" name="tip" id="tip@(t.Item1)" value="@t.Item1" @(t.Item1 == "0" ? "checked" : "") />
                    <label class="tip-pill" for="tip@(t.Item1)">@t.Item2</label>
                }
            </div>
            <div class="tip-other">
                <span class="tip-other-label">Other:</span>
                <input class="tip-other-input" type="number" name="tipOther" min="0" step="0.01"
                       placeholder="0,00" id="tipOtherInput" />
            </div>
        </div>

        <!-- Payment method -->
        <div class="section-card">
            <div class="section-title">Payment method</div>
            <div class="method-grid">
                <div class="method-option">
                    <input class="method-radio" type="radio" name="paymentMethod" id="methodCard" value="pin" checked />
                    <label class="method-card" for="methodCard">
                        <div class="method-card-icon">💳</div>
                        <div class="method-card-label">Card / PIN</div>
                    </label>
                </div>
                <div class="method-option">
                    <input class="method-radio" type="radio" name="paymentMethod" id="methodCash" value="cash" />
                    <label class="method-card" for="methodCash">
                        <div class="method-card-icon">💵</div>
                        <div class="method-card-label">Cash</div>
                    </label>
                </div>
            </div>
        </div>

        <button type="submit" class="btn-process" id="processBtn">
            💳 Process payment — €@Model.TotalToPay.ToString("0.00")
        </button>
    </form>
</div>

<!-- Split modal -->
<div class="modal-overlay" id="splitModal">
    <div class="modal">
        <div class="modal-head">
            <h3>⋈ Split bill</h3>
            <button type="button" class="modal-close" onclick="closeSplit()">×</button>
        </div>
        <div class="modal-body">
            <div class="split-tabs">
                <button type="button" class="split-tab-btn active" id="tabEvenBtn" onclick="switchTab('even')">Even split</button>
                <button type="button" class="split-tab-btn" id="tabItemBtn" onclick="switchTab('item')">By item</button>
            </div>

            <!-- Even split panel -->
            <div id="panelEven">
                <div class="ways-row">
                    <span class="ways-label">Even split</span>
                    <div class="ways-ctrl">
                        <button type="button" class="ways-btn minus" onclick="changeWays(-1)">−</button>
                        <span class="ways-count" id="waysDisplay">2 ways</span>
                        <button type="button" class="ways-btn plus" onclick="changeWays(1)">+</button>
                    </div>
                </div>
                <div class="per-person-box">
                    <div class="per-person-label">Each pays</div>
                    <div class="per-person-amount" id="perPersonAmount">€@((Model.TotalToPay / 2).ToString("0.00"))</div>
                    <div class="per-person-sub">per person · Total €@Model.TotalToPay.ToString("0.00")</div>
                </div>
                <div id="guestList"></div>
            </div>

            <!-- By item panel -->
            <div id="panelItem" style="display:none">
                <div class="ways-row">
                    <span class="ways-label">By item</span>
                    <div class="ways-ctrl">
                        <button type="button" class="ways-btn minus" onclick="changeWays(-1)">−</button>
                        <span class="ways-count" id="waysDisplayItem">2 ways</span>
                        <button type="button" class="ways-btn plus" onclick="changeWays(1)">+</button>
                    </div>
                </div>
                <div class="byitem-hint">Tap an item to assign it to a guest</div>
                <div class="byitem-list" id="byitemList"></div>
                <div class="byitem-totals" id="byitemTotals"></div>
            </div>

            <button type="button" class="btn-process" onclick="applySplit()">Apply split &amp; pay</button>
        </div>
    </div>
</div>

<script>
    var total   = @Model.TotalToPay.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture);
    var ways    = 2;
    var curTab  = 'even';
    var colors  = ['#7a2a3e','#1a3a5c','#2a5c3a','#5c3a1a','#3a1a5c','#5c1a3a'];

    // flat items: name + price each unit
    var allItems = [
        @foreach (var item in flatItems)
        {
                @:{ name: "@Html.Raw(item.Name.Replace("\"", "\\\""))", price: @item.UnitPrice.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) },
        }
    ];
    // assigned[i] = guest index (0-based), -1 = unassigned
    var assigned = allItems.map(function() { return -1; });

    function openSplit() {
        document.getElementById('splitModal').classList.add('open');
        renderEven(); renderByItem();
    }
    function closeSplit() {
        document.getElementById('splitModal').classList.remove('open');
    }

    function switchTab(tab) {
        curTab = tab;
        document.getElementById('tabEvenBtn').className = 'split-tab-btn' + (tab==='even'?' active':'');
        document.getElementById('tabItemBtn').className  = 'split-tab-btn' + (tab==='item'?' active':'');
        document.getElementById('panelEven').style.display = tab==='even' ? '' : 'none';
        document.getElementById('panelItem').style.display = tab==='item' ? '' : 'none';
    }

    function changeWays(delta) {
        ways = Math.max(2, Math.min(10, ways + delta));
        assigned = assigned.map(function() { return -1; });
        renderEven(); renderByItem();
    }

    function renderEven() {
        document.getElementById('waysDisplay').textContent = ways + ' ways';
        var per = Math.round(total / ways * 100) / 100;
        document.getElementById('perPersonAmount').textContent = '€' + per.toFixed(2);
        var html = '';
        for (var i = 0; i < ways; i++) {
            var amt = i === ways-1 ? (total - per*(ways-1)).toFixed(2) : per.toFixed(2);
            html += '<div class="guest-row"><div style="display:flex;align-items:center">' +
                '<div class="guest-av" style="background:' + colors[i] + '">' + (i+1) + '</div>' +
                '<span style="font-size:14px;color:#2a1a1f">Guest ' + (i+1) + '</span></div>' +
                '<span style="font-size:14px;font-weight:700;color:#2a1a1f">€' + amt + '</span></div>';
        }
        document.getElementById('guestList').innerHTML = html;
    }

    function renderByItem() {
        document.getElementById('waysDisplayItem').textContent = ways + ' ways';
        var listHtml = '';
        allItems.forEach(function(item, idx) {
            var chips = '';
            for (var g = 0; g < ways; g++) {
                chips += '<div class="assign-chip ' + (assigned[idx]===g?'active':'') + '" ' +
                    'style="background:' + colors[g] + '" data-idx="' + idx + '" data-g="' + g + '" ' +
                    'onclick="assignItem(' + idx + ',' + g + ')">' + (g+1) + '</div>';
            }
            listHtml += '<div class="byitem-row">' +
                '<div><div class="byitem-name">' + item.name + '</div></div>' +
                '<div style="display:flex;align-items:center;gap:10px">' +
                '<span class="byitem-price">€' + item.price.toFixed(2) + '</span>' +
                '<div class="byitem-assign">' + chips + '</div></div></div>';
        });
        document.getElementById('byitemList').innerHTML = listHtml;

        var totals = new Array(ways).fill(0);
        allItems.forEach(function(item, idx) {
            if (assigned[idx] >= 0) totals[assigned[idx]] += item.price;
        });
        var totHtml = '';
        for (var g = 0; g < ways; g++) {
            totHtml += '<div class="byitem-total-box" style="background:' + colors[g] + '">' +
                '<div class="byitem-total-name">Guest ' + (g+1) + '</div>' +
                '<div class="byitem-total-amt">€' + totals[g].toFixed(2) + '</div></div>';
        }
        document.getElementById('byitemTotals').innerHTML = totHtml;
    }

    function assignItem(idx, g) {
        assigned[idx] = assigned[idx] === g ? -1 : g;
        renderByItem();
    }

    function applySplit() {
        document.getElementById('splitWaysInput').value = ways;
        closeSplit();
        document.getElementById('payForm').submit();
    }

    // Update process button when tip changes
    document.querySelectorAll('.tip-radio').forEach(function(r) {
        r.addEventListener('change', function() {
            document.getElementById('tipOtherInput').value = '';
            updateProcessBtn();
        });
    });
    document.getElementById('tipOtherInput').addEventListener('input', function() {
        document.querySelectorAll('.tip-radio').forEach(function(r) { r.checked = false; });
        updateProcessBtn();
    });
    function updateProcessBtn() {
        var tipRadio = document.querySelector('.tip-radio:checked');
        var tipOther = parseFloat(document.getElementById('tipOtherInput').value) || 0;
        var tip = tipOther > 0 ? tipOther : (tipRadio ? parseFloat(tipRadio.value) : 0);
        var t = total + tip;
        document.getElementById('processBtn').innerHTML = '💳 Process payment — €' + t.toFixed(2);
    }

    // init even split list on load
    renderEven();
</script>
