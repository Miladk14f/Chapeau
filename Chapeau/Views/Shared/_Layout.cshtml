<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Chapeau</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', system-ui, sans-serif;
            background: #f5f0eb;
            color: #2a1a1f;
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* ── Sidebar ── */
        .sidebar {
            width: 76px;
            background: #1a0d12;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 16px 0;
            gap: 4px;
            flex-shrink: 0;
        }

        .sidebar-logo {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: #7a2a3e;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            font-weight: 700;
            color: #e8c9a0;
            margin-bottom: 20px;
            text-decoration: none;
        }

        .nav-item {
            width: 56px;
            height: 56px;
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 4px;
            text-decoration: none;
            color: #6b5560;
            font-size: 10px;
            font-weight: 600;
            transition: background 0.15s, color 0.15s;
            cursor: pointer;
        }

        .nav-item:hover {
            background: #2e1520;
            color: #c9843a;
        }

        .nav-item.active {
            background: #7a2a3e;
            color: #f0e6d8;
        }

        .nav-icon { font-size: 20px; line-height: 1; }

        /* ── Main area ── */
        .main-wrap {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        /* ── Top bar ── */
        .topbar {
            background: #2a1218;
            display: flex;
            align-items: center;
            padding: 0 24px;
            height: 64px;
            flex-shrink: 0;
            gap: 16px;
        }

        .topbar-brand {
            display: flex;
            flex-direction: column;
            line-height: 1.2;
        }

        .topbar-brand-name {
            font-size: 16px;
            font-weight: 700;
            color: #f0e6d8;
            font-family: Georgia, serif;
        }

        .topbar-brand-sub {
            font-size: 11px;
            color: #6b5560;
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-left: auto;
        }

        .topbar-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: #7a2a3e;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 700;
            color: #f0e6d8;
        }

        .topbar-user {
            line-height: 1.2;
        }

        .topbar-user-name {
            font-size: 14px;
            font-weight: 600;
            color: #f0e6d8;
        }

        .topbar-user-role {
            font-size: 11px;
            color: #6b5560;
        }

        .topbar-logout {
            color: #6b5560;
            text-decoration: none;
            font-size: 18px;
            padding: 4px 8px;
            border-radius: 6px;
            transition: color 0.15s;
        }

        .topbar-logout:hover { color: #c9843a; }

        /* ── Page content ── */
        .page-content {
            flex: 1;
            overflow-y: auto;
            padding: 32px 36px;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Chapeau</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Bar" asp-action="Index">Bar</a>
                        </li>
                    </ul>
                </div>
                <a class="topbar-logout" asp-controller="Staff" asp-action="Logout" title="Sign out">⇥</a>
            </div>
        </header>

        <!-- Page body -->
        <div class="page-content">
            @RenderBody()
        </div>

    </div>

</body>
</html>
