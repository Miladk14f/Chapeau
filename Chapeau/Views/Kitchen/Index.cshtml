@model List<Chapeau.ViewModels.PreparationCard>
@{
    ViewData["Title"] = "Kitchen";
    int pending = Model?.Count(c => !c.IsUrgent && !c.IsWarning) ?? 0;
    int warning = Model?.Count(c => c.IsWarning) ?? 0;
    int urgent = Model?.Count(c => c.IsUrgent) ?? 0;
}

<div class="kitchen-page">
<div class="kitchen-header">
    <div class="kitchen-icon">🍳</div>
    <div>
        <h1>Kitchen</h1>
        <div class="kitchen-sub">
            @(Model?.Count ?? 0) orders ·
            @if (urgent > 0)
            {
                <span class="urgent-txt">@urgent urgent!</span>
            }
            else
            {
                <span>0 urgent</span>
            }
        </div>
    </div>
</div>

@if (Model == null || !Model.Any())
{
    <div class="empty-state">No pending food orders.</div>
}
else
{
    <div class="cards-grid">
        @foreach (var card in Model)
        {
            string cardClass = card.IsUrgent ? "urgent" : card.IsWarning ? "warning" : "";
            string timeClass = card.IsUrgent ? "urgent" : card.IsWarning ? "warning" : "";
            string timeText = card.MinutesAgo < 1 ? "just now" : $"{card.MinutesAgo} min ago";

            <div class="order-card @cardClass">
                <div class="card-top">
                    <span class="table-badge">Table @card.TableId</span>
                    <span class="time-ago @timeClass">🕐 @timeText</span>
                </div>

                @if (card.IsUrgent)
                {
                    <div class="wait-exceeded">⊘ Wait time exceeded!</div>
                }

                @if (card.IsPreparing)
                {
                    <div class="prep-label">👨‍🍳 In preparation</div>
                }

                <div class="items-list">
                    @foreach (var item in card.Items)
                    {
                        string itemTime = item.MinutesAgo < 1 ? "just now" : $"{item.MinutesAgo} min ago";
                        <div class="item-row">
                            <div class="item-left">
                                <span class="item-qty">@(item.Qty)×</span>
                                <div class="item-info">
                                    <span class="item-name">@item.Name</span>
                                    @if (!string.IsNullOrEmpty(item.Note))
                                    {
                                        <span class="item-note">📝 @item.Note</span>
                                    }
                                </div>
                            </div>
                            <span class="item-time">@itemTime</span>
                        </div>
                    }
                </div>

                <div class="card-footer">
                    <span class="ordered-by">Ordered by: @card.StaffName</span>
                    @if (card.IsPreparing)
                    {
                        <form method="post" asp-action="MarkReady">
                            <input type="hidden" name="orderId" value="@card.OrderId" />
                            <button type="submit" class="btn-ready">✓ Ready</button>
                        </form>
                    }
                    else
                    {
                        <form method="post" asp-action="StartPreparing">
                            <input type="hidden" name="orderId" value="@card.OrderId" />
                            <button type="submit" class="btn-start">▶ Start preparing</button>
                        </form>
                    }
                </div>
            </div>
        }
    </div>
}

<div class="legend">
    <div class="legend-item"><div class="legend-box normal"></div> &lt; 12 min</div>
    <div class="legend-item"><div class="legend-box warning"></div> 12–19 min</div>
    <div class="legend-item"><div class="legend-box urgent"></div> ≥ 20 min (urgent)</div>
</div>
</div>
