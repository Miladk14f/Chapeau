@model List<Chapeau.Models.Comment>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Kitchen Display";
}

<div class="container-fluid mt-3" style="font-family: sans-serif;">
    <div class="d-flex justify-content-between align-items-center bg-dark text-white p-3 rounded mb-4">
        <h1 class="h3 mb-0">KITCHEN DISPLAY SYSTEM</h1>
        <span class="badge bg-danger">Active Tickets</span>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
        <div class="col">
            <div class="card h-100 border-primary shadow">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <strong style="font-size: 1.25rem;">Table #1</strong>
                    <span>Active Ticket</span>
                </div>
                <div class="card-body">

                    @if (Model != null && Model.Count > 0)
                    {
                        foreach (var comment in Model)
                        {
                            <div class="alert alert-warning py-1 px-2 mb-2 small fw-bold">
                                NOTE (@comment.Type): @comment.Text
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-muted small">No special preparation instructions.</div>
                    }

                    <ul class="list-group list-group-flush mt-3" style="font-size: 1.1rem;">
                        <li class="list-group-item">
                            <span><mark class="bg-warning fw-bold">1x</mark> Grilled Salmon</span>
                        </li>
                    </ul>
                </div>
                <div class="card-footer bg-white border-0">
                    <button class="btn btn-success w-100 py-2 fw-bold">
                        ✔ MARK READY
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>