@model List<Chapeau.Models.RestaurantTable>
@using Chapeau.Models.Enums
@{
    ViewData["Title"] = "Tables";
    var occupied  = Model?.Count(t => t.Status == ETableStatus.Occupied) ?? 0;
    var reserved  = Model?.Count(t => t.Status == ETableStatus.Reserved || (t.ReservationName != null && t.Status != ETableStatus.Occupied)) ?? 0;
    var available = Model?.Count(t => t.Status != ETableStatus.Occupied && t.ReservationName == null) ?? 0;
}

<style>
    .fp-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
    }

    .fp-header h1 {
        font-size: 28px;
        font-weight: 700;
        color: #2a1a1f;
        font-family: Georgia, serif;
    }

    .btn-reservation {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: #3a5fd9;
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
    }

    .fp-stats {
        display: flex;
        gap: 10px;
        margin-bottom: 24px;
    }

    .stat-badge {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 20px;
        border: 1px solid #d0c8c0;
        background: #fff;
        font-size: 13px;
        font-weight: 600;
        color: #2a1a1f;
    }

    .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    .dot-occupied  { background: #e87d3e; }
    .dot-available { background: #3db87a; }
    .dot-reserved  { background: #7c5cbf; }

    /* ── Table grid ── */
    .table-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 16px;
        margin-bottom: 36px;
    }

    .table-card {
        background: #f0faf4;
        border: 2px solid #a8e0be;
        border-radius: 14px;
        padding: 18px 16px 14px;
        position: relative;
        text-decoration: none;
        color: inherit;
        display: block;
        transition: box-shadow 0.15s;
    }

    .table-card:hover { box-shadow: 0 4px 16px rgba(61,184,122,0.2); }

    .table-card.occupied {
        background: #fff8f3;
        border-color: #f0b88a;
    }

    .table-card.reserved {
        background: #f5f3ff;
        border-color: #c4b5f4;
    }

    .status-badge {
        position: absolute;
        top: 14px;
        right: 14px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
    }

    .badge-available { background: #3db87a; color: #fff; }
    .badge-occupied  { background: #e87d3e; color: #fff; }
    .badge-reserved  { background: #7c5cbf; color: #fff; }

    .table-name {
        font-size: 20px;
        font-weight: 700;
        color: #1a3a2a;
        margin-bottom: 8px;
        font-family: Georgia, serif;
    }

    .table-card.occupied .table-name { color: #3a1a0a; }

    .table-persons {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: #4a7a5a;
        margin-bottom: 12px;
    }

    .table-card.occupied .table-persons { color: #7a4a2a; }

    .table-action {
        font-size: 13px;
        font-weight: 600;
        color: #2d7a50;
        text-decoration: none;
    }

    .table-card.occupied .table-action { color: #c05a20; }

    .table-arrow {
        position: absolute;
        bottom: 14px;
        right: 14px;
        color: #a8e0be;
        font-size: 16px;
    }

    .table-card.occupied .table-arrow { color: #f0b88a; }

    /* ── Legend ── */
    .legend {
        display: flex;
        gap: 24px;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: #6b5560;
    }

    .legend-box {
        width: 16px;
        height: 16px;
        border-radius: 4px;
        border: 2px solid;
    }

    .legend-box.available { border-color: #a8e0be; background: #f0faf4; }
    .legend-box.occupied  { border-color: #f0b88a; background: #fff8f3; }
    .legend-box.reserved  { border-color: #c4b5f4; background: #f5f3ff; }
</style>

<div class="fp-header">
    <h1>Floor plan</h1>
    <a asp-controller="RestaurantTable" asp-action="Reserve" class="btn-reservation">⊞ Reservation</a>
</div>

<div class="fp-stats">
    <div class="stat-badge"><span class="dot dot-occupied"></span> @occupied occupied</div>
    <div class="stat-badge"><span class="dot dot-available"></span> @available available</div>
    <div class="stat-badge"><span class="dot dot-reserved"></span> @reserved reserved</div>
</div>

<div class="table-grid">
    @if (Model != null)
    {
        @foreach (var table in Model)
        {
            var isOccupied = table.Status == ETableStatus.Occupied;
            var isReserved = table.ReservationName != null && !isOccupied;
            var cardClass  = isOccupied ? "occupied" : isReserved ? "reserved" : "";
            var badgeClass = isOccupied ? "badge-occupied" : isReserved ? "badge-reserved" : "badge-available";
            var badgeText  = isOccupied ? "Occupied" : isReserved ? "Reserved" : "Available";

            <a class="table-card @cardClass" asp-controller="RestaurantTable" asp-action="Details" asp-route-id="@table.TableId">
                <span class="status-badge @badgeClass">@badgeText</span>
                <div class="table-name">Table @table.TableId</div>
                <div class="table-persons">👥 @(table.Guests ?? table.Seats) persons</div>
                <span class="table-action">+ Open table</span>
                <span class="table-arrow">›</span>
            </a>
        }
    }
</div>

<div class="legend">
    <div class="legend-item"><div class="legend-box available"></div> Available</div>
    <div class="legend-item"><div class="legend-box occupied"></div> Occupied</div>
    <div class="legend-item"><div class="legend-box reserved"></div> Reserved</div>
</div>
