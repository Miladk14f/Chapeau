@model Chapeau.ViewModels.TableOverviewViewModel
@using Chapeau.Models.Enums
@{
    ViewData["Title"] = "Tables";
    var occupied  = Model.Cards.Count(c => c.Table.Status == TableStatus.Occupied);
    var reserved  = Model.Cards.Count(c => c.Table.Status == TableStatus.Reserved || (c.Table.ReservationName != null && c.Table.Status != TableStatus.Occupied));
    var available = Model.Cards.Count(c => c.Table.Status != TableStatus.Occupied && c.Table.ReservationName == null);
}

<style>
    .fp-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
    }

    .fp-header h1 {
        font-size: 28px;
        font-weight: 700;
        color: #2a1a1f;
        font-family: Georgia, serif;
    }

    .btn-reservation {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: #3a5fd9;
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
    }

    .fp-stats {
        display: flex;
        gap: 10px;
        margin-bottom: 24px;
    }

    .stat-badge {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 20px;
        border: 1px solid #d0c8c0;
        background: #fff;
        font-size: 13px;
        font-weight: 600;
        color: #2a1a1f;
    }

    .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    .dot-occupied  { background: #e87d3e; }
    .dot-available { background: #3db87a; }
    .dot-reserved  { background: #7c5cbf; }

    /* ── Table grid ── */
    .table-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 16px;
        margin-bottom: 36px;
    }

    .table-card {
        background: #f0faf4;
        border: 2px solid #a8e0be;
        border-radius: 14px;
        padding: 18px 16px 14px;
        position: relative;
        text-decoration: none;
        color: inherit;
        display: block;
        transition: box-shadow 0.15s;
    }

    .table-card:hover { box-shadow: 0 4px 16px rgba(61,184,122,0.2); }

    .table-card.occupied {
        background: #fff8f3;
        border-color: #f0b88a;
    }

    .table-card.reserved {
        background: #f5f3ff;
        border-color: #c4b5f4;
    }

    .status-badge {
        position: absolute;
        top: 14px;
        right: 14px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
    }

    .badge-available { background: #3db87a; color: #fff; }
    .badge-occupied  { background: #e87d3e; color: #fff; }
    .badge-reserved  { background: #7c5cbf; color: #fff; }

    .table-name {
        font-size: 20px;
        font-weight: 700;
        color: #1a3a2a;
        margin-bottom: 8px;
        font-family: Georgia, serif;
    }

    .table-card.occupied .table-name { color: #3a1a0a; }

    .table-persons {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: #4a7a5a;
        margin-bottom: 12px;
    }

    .table-card.occupied .table-persons { color: #7a4a2a; }

    .table-action {
        font-size: 13px;
        font-weight: 600;
        color: #2d7a50;
        text-decoration: none;
    }

    .table-card.occupied .table-action { color: #c05a20; }

    .table-arrow {
        position: absolute;
        bottom: 14px;
        right: 14px;
        color: #a8e0be;
        font-size: 16px;
    }

    .table-card.occupied .table-arrow { color: #f0b88a; }

    /* ── Legend ── */
    .legend {
        display: flex;
        gap: 24px;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: #6b5560;
    }

    .legend-box {
        width: 16px;
        height: 16px;
        border-radius: 4px;
        border: 2px solid;
    }

    .legend-box.available { border-color: #a8e0be; background: #f0faf4; }
    .legend-box.occupied  { border-color: #f0b88a; background: #fff8f3; }
    .legend-box.reserved  { border-color: #c4b5f4; background: #f5f3ff; }

    /* ── Ready notifications ── */
    .table-card.has-ready { border-color: #e0b020; box-shadow: 0 0 0 2px #f0d88040; }
    .ready-notes { margin-top: 10px; display: flex; flex-direction: column; gap: 6px; }
    .ready-note {
        border-radius: 10px; padding: 8px 10px;
    }
    .ready-note.food  { background: #eafaf0; border: 1px solid #a8e0be; }
    .ready-note.drink { background: #e9f1ff; border: 1px solid #aecbf5; }
    .ready-note.preparing { background: #fff6e0; border: 1px solid #f0d080; }
    .ready-note.preparing .ready-note-head { color: #a06a00; }
    .ready-note-head {
        display: flex; align-items: center; gap: 6px;
        font-size: 11px; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.04em; margin-bottom: 4px;
    }
    .ready-note.food  .ready-note-head { color: #2a7a48; }
    .ready-note.drink .ready-note-head { color: #2a4f9a; }
    .ready-note-items { font-size: 12px; color: #4a3a2a; line-height: 1.5; }
    .ready-note.drink .ready-note-items { color: #2a3a5a; }

    .ready-pip {
        position: absolute; top: 14px; left: 14px;
        display: flex; gap: 4px;
    }
    .pip {
        width: 18px; height: 18px; border-radius: 50%;
        font-size: 10px; font-weight: 700; color: #fff;
        display: flex; align-items: center; justify-content: center;
    }
    .pip.food  { background: #e0a020; }
    .pip.drink { background: #3a5fd9; }
</style>

<div class="fp-header">
    <h1>Floor plan</h1>
    <a asp-controller="RestaurantTable" asp-action="Reserve" class="btn-reservation">⊞ Reservation</a>
</div>

<div class="fp-stats">
    <div class="stat-badge"><span class="dot dot-occupied"></span> @occupied occupied</div>
    <div class="stat-badge"><span class="dot dot-available"></span> @available available</div>
    <div class="stat-badge"><span class="dot dot-reserved"></span> @reserved reserved</div>
</div>

<div class="table-grid">
    @foreach (var card in Model.Cards)
    {
        var table = card.Table;
        var isOccupied = table.Status == TableStatus.Occupied;
        var isReserved = table.ReservationName != null && !isOccupied;
        var cardClass  = isOccupied ? "occupied" : isReserved ? "reserved" : "";
        var badgeClass = isOccupied ? "badge-occupied" : isReserved ? "badge-reserved" : "badge-available";
        var badgeText  = isOccupied ? "Occupied" : isReserved ? "Reserved" : "Available";
        var hasReady     = card.ReadyFood.Any() || card.ReadyDrink.Any();
        var hasPreparing = card.PreparingFood.Any() || card.PreparingDrink.Any();

        <a class="table-card @cardClass @(hasReady ? "has-ready" : "")" asp-controller="Order" asp-action="CreateOrder" asp-route-tableId="@table.TableId">
            <span class="status-badge @badgeClass">@badgeText</span>
            <div class="table-name">Table @table.TableId</div>
            <div class="table-persons">👥 @(table.Guests ?? table.Seats) persons</div>
            <span class="table-action">+ Open table</span>
            <span class="table-arrow">›</span>

            @if (hasPreparing || hasReady)
            {
                <div class="ready-notes">
                    @if (card.PreparingFood.Any())
                    {
                        <div class="ready-note preparing">
                            <div class="ready-note-head">👨‍🍳 Food in preparation (@card.PreparingFoodCount)</div>
                            <div class="ready-note-items">
                                @foreach (var item in card.PreparingFood)
                                {
                                    <div>@item.Qty× @item.Name</div>
                                }
                            </div>
                        </div>
                    }
                    @if (card.PreparingDrink.Any())
                    {
                        <div class="ready-note preparing">
                            <div class="ready-note-head">🍸 Drinks in preparation (@card.PreparingDrinkCount)</div>
                            <div class="ready-note-items">
                                @foreach (var item in card.PreparingDrink)
                                {
                                    <div>@item.Qty× @item.Name</div>
                                }
                            </div>
                        </div>
                    }
                    @if (card.ReadyFood.Any())
                    {
                        <div class="ready-note food">
                            <div class="ready-note-head">🍽 Food ready (@card.ReadyFoodCount)</div>
                            <div class="ready-note-items">
                                @foreach (var item in card.ReadyFood)
                                {
                                    <div>@item.Qty× @item.Name</div>
                                }
                            </div>
                        </div>
                    }
                    @if (card.ReadyDrink.Any())
                    {
                        <div class="ready-note drink">
                            <div class="ready-note-head">🍷 Drinks ready (@card.ReadyDrinkCount)</div>
                            <div class="ready-note-items">
                                @foreach (var item in card.ReadyDrink)
                                {
                                    <div>@item.Qty× @item.Name</div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </a>
    }
</div>

<div class="legend">
    <div class="legend-item"><div class="legend-box available"></div> Available</div>
    <div class="legend-item"><div class="legend-box occupied"></div> Occupied</div>
    <div class="legend-item"><div class="legend-box reserved"></div> Reserved</div>
</div>
