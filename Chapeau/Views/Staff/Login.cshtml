@model List<Chapeau.Models.Staff>
@using Chapeau.Models.Enums
@{
    Layout = null;
    int selectedId = ViewBag.SelectedStaffId ?? 0;

    var roleGroups = new[]
    {
        new { Label = "Manager", Icon = "📊", Key = StaffRole.Manager },
        new { Label = "Chef",    Icon = "🍽",  Key = StaffRole.Chef    },
        new { Label = "Bar",     Icon = "🍷",  Key = StaffRole.Bar     },
        new { Label = "Service", Icon = "⊞",  Key = StaffRole.Waiter  },
    };

    string Initials(string name) =>
        string.Concat(name.Split(' ').Where(w => w.Length > 0).Take(2).Select(w => w[0].ToString().ToUpper()));

    string AvatarColor(int id)
    {
        return (id % 6) switch
        {
            0 => "#8b3a52",
            1 => "#2d6e4e",
            2 => "#2a4f7a",
            3 => "#7a5a1a",
            4 => "#4a2e7a",
            _ => "#1e5c5c"
        };
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Chapeau – Sign In</title>
    <link rel="stylesheet" href="~/css/chapeau.css" />
</head>
<body class="login-body">

    <div class="logo-circle">C</div>
    <h1>Chapeau</h1>
    <p class="subtitle">Zeewolde · Ordering System</p>
    <p class="hint">Select your name to sign in</p>

    <div class="login-wrap">

        @foreach (var group in roleGroups)
        {
            var members = Model?.Where(s => s.Role == group.Key).ToList();
            if (members == null || members.Count == 0) continue;

            <div class="role-section">
                <div class="role-label"><span>@group.Icon</span> @group.Label</div>
                <div class="staff-grid">
                    @foreach (var staff in members)
                    {
                        <form method="post" action="/Staff/Select">
                            <input type="hidden" name="staffId" value="@staff.StaffId" />
                            <button type="submit" class="staff-card @(staff.StaffId == selectedId ? "active" : "")">
                                <div class="avatar" style="background:@AvatarColor(staff.StaffId)">@Initials(staff.Name)</div>
                                <div class="card-info">
                                    <div class="card-firstname">@staff.Name.Split(' ').FirstOrDefault()</div>
                                    <div class="card-lastname">@staff.Name.Split(' ').Skip(1).FirstOrDefault()</div>
                                </div>
                            </button>
                        </form>
                    }
                </div>
            </div>
        }

        <!-- PASSWORD -->
        <form method="post" action="/Staff/Login">
            <div class="password-section">
                @if (selectedId > 0)
                {
                    var selected = Model?.FirstOrDefault(s => s.StaffId == selectedId);
                    if (selected != null)
                    {
                        <p class="selected-staff-hint">Signing in as <span>@selected.Name</span></p>
                    }
                }
                else
                {
                    <p class="selected-staff-hint">Select a staff member above first</p>
                }

                @if (!string.IsNullOrEmpty(ViewBag.Error as string))
                {
                    <p class="error-msg">@ViewBag.Error</p>
                }

                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="Enter your password" />
                <button type="submit" class="btn-signin">Sign in →</button>
            </div>
        </form>

    </div>

    <footer>© 2025 Restaurant Chapeau, Zeewolde</footer>

</body>
</html>
