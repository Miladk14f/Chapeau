@model Chapeau.ViewModels.ManagerDashboardViewModel
@{
    ViewData["Title"] = "Manager Dashboard";
    string Tab(string t) => Model.ActiveTab == t ? "tab-btn active" : "tab-btn";

    decimal vat9Total = Model.Vat9ExclBtw + Model.Vat9Amount;
    decimal vat21Total = Model.Vat21ExclBtw + Model.Vat21Amount;
    decimal vatExclAll = Model.Vat9ExclBtw + Model.Vat21ExclBtw;
    decimal vatAmtAll = Model.Vat9Amount + Model.Vat21Amount;
    decimal vatInclAll = vat9Total + vat21Total;

    var filteredStock = Model.StockFilter switch
    {
        "low" => Model.StockItems.Where(s => s.IsLow && !s.IsOut).ToList(),
        "out" => Model.StockItems.Where(s => s.IsOut).ToList(),
        _ => Model.StockItems
    };

    decimal maxRevenue = Model.CategoryRevenues.Any() ? Model.CategoryRevenues.Max(c => c.Amount) : 1;
}

<!-- Header -->
<div class="mgr-header">
    <div class="mgr-header-icon">📊</div>
    <div>
        <h1>Manager Dashboard</h1>
        <p>Restaurant Chapeau · @DateTime.Now.ToString("dddd d MMMM")</p>
    </div>
</div>

<!-- Stat cards -->
<div class="stat-grid">
    <div class="stat-card">
        <div class="stat-icon">€</div>
        <div class="stat-value">€@Model.RevenuePaid.ToString("0.00")</div>
        <div class="stat-label">Revenue (paid)</div>
        <div class="stat-sub">+ €@Model.RevenueOpen.ToString("0.00") open</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">👥</div>
        <div class="stat-value">@Model.CoversToday</div>
        <div class="stat-label">Covers today</div>
        <div class="stat-sub">@Model.CoversSeated at table</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">📈</div>
        <div class="stat-value">€@Model.TipsReceived.ToString("0.00")</div>
        <div class="stat-label">Tips received</div>
        <div class="stat-sub">@Model.TablesCheckedOut tables checked out</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">📦</div>
        <div class="stat-value">@(Model.StockOutCount + Model.StockLowCount)</div>
        <div class="stat-label">Stock warnings</div>
        <div class="stat-sub">@Model.StockOutCount out · @Model.StockLowCount low</div>
    </div>
</div>

<!-- Tab nav -->
<div class="tab-nav">
    <a class="@Tab("revenue")" asp-controller="Manager" asp-action="Index" asp-route-tab="revenue">Revenue</a>
    <a class="@Tab("vat")" asp-controller="Manager" asp-action="Index" asp-route-tab="vat">VAT</a>
    <a class="@Tab("stock")" asp-controller="Manager" asp-action="Index" asp-route-tab="stock">Stock</a>
    <a class="@Tab("feedback")" asp-controller="Manager" asp-action="Index" asp-route-tab="feedback">Feedback</a>
    <a class="@Tab("orders")" asp-controller="Manager" asp-action="Index" asp-route-tab="orders">Orders</a>
</div>

<!-- ── REVENUE TAB ── -->
@if (Model.ActiveTab == "revenue")
{
    <div class="panel">
        <div class="panel-title">Revenue by category</div>
        @if (Model.CategoryRevenues.Any())
        {
            <div class="bar-chart">
                @foreach (var cat in Model.CategoryRevenues.OrderByDescending(c => c.Amount))
                {
                    int pct = (int)(cat.Amount / maxRevenue * 100);
                    <div class="bar-row">
                        <div class="bar-label">@cat.Category</div>
                        <div class="bar-track">
                            @if (pct > 0)
                            {
                                <div class="bar-fill" style="width:@pct%">
                                    <span class="bar-amount">€@cat.Amount.ToString("0.00")</span>
                                </div>
                            }
                            else
                            {
                                <span class="bar-empty">€0.00</span>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="empty-state">No revenue data yet.</p>
        }
    </div>

    <div class="panel">
        <div class="panel-title">Staff performance</div>
        @if (Model.StaffPerformances.Any())
        {
            decimal maxStaffRev = Model.StaffPerformances.Max(s => s.Revenue);
            @foreach (var s in Model.StaffPerformances.OrderByDescending(s => s.Revenue))
            {
                int pct = maxStaffRev > 0 ? (int)(s.Revenue / maxStaffRev * 100) : 0;
                <div class="staff-row">
                    <div class="staff-av">@s.Initials</div>
                    <div class="staff-info">
                        <div class="staff-name">@s.Name</div>
                        <div class="staff-items">@s.Items items ordered</div>
                        <div class="staff-bar-track">
                            <div class="staff-bar-fill" style="width:@pct%"></div>
                        </div>
                    </div>
                    <div class="staff-revenue">€@s.Revenue.ToString("0.00")</div>
                </div>
            }
        }
        else
        {
            <p class="empty-state">No staff data yet.</p>
        }
    </div>
}

<!-- ── VAT TAB ── -->
@if (Model.ActiveTab == "vat")
{
    <div class="panel">
        <div class="vat-header">
            <h3>VAT specification</h3>
            <p>All orders today (open + paid)</p>
        </div>
        <table class="vat-table">
            <thead>
                <tr>
                    <th>Rate</th>
                    <th>Excl. VAT</th>
                    <th>VAT</th>
                    <th>Incl. VAT</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>
                        <div><span class="vat-badge vat-badge--9">9%</span></div>
                        <div class="vat-sub">Food &amp; soft drinks</div>
                    </td>
                    <td>€@Model.Vat9ExclBtw.ToString("0.00")</td>
                    <td class="vat-amount">€@Model.Vat9Amount.ToString("0.00")</td>
                    <td>€@vat9Total.ToString("0.00")</td>
                </tr>
                <tr>
                    <td>
                        <div><span class="vat-badge vat-badge--21">21%</span></div>
                        <div class="vat-sub">Alcohol</div>
                    </td>
                    <td>€@Model.Vat21ExclBtw.ToString("0.00")</td>
                    <td class="vat-amount">€@Model.Vat21Amount.ToString("0.00")</td>
                    <td>€@vat21Total.ToString("0.00")</td>
                </tr>
                <tr>
                    <td>Total</td>
                    <td>€@vatExclAll.ToString("0.00")</td>
                    <td class="vat-amount">€@vatAmtAll.ToString("0.00")</td>
                    <td>€@vatInclAll.ToString("0.00")</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="panel">
        <div class="panel-title">VAT distribution</div>
        <div class="pie-wrap">
            <div class="pie"></div>
            <div class="pie-legend">
                <div class="pie-legend-item">
                    <div class="pie-dot pie-dot--9"></div>
                    VAT 9% (food/soft drinks): €@Model.Vat9Amount.ToString("0.00")
                </div>
                <div class="pie-legend-item">
                    <div class="pie-dot pie-dot--21"></div>
                    VAT 21% (alcohol): €@Model.Vat21Amount.ToString("0.00")
                </div>
            </div>
        </div>
    </div>
}

<!-- ── STOCK TAB ── -->
@if (Model.ActiveTab == "stock")
{
    <div class="filter-pills">
        <a class="pill @(Model.StockFilter == "all" ? "active" : "")"
           asp-controller="Manager" asp-action="Index" asp-route-tab="stock" asp-route-stockFilter="all">
            All (@Model.StockItems.Count)
        </a>
        <a class="pill @(Model.StockFilter == "low" ? "active" : "")"
           asp-controller="Manager" asp-action="Index" asp-route-tab="stock" asp-route-stockFilter="low">
            Low (@Model.StockItems.Count(s => s.IsLow && !s.IsOut))
        </a>
        <a class="pill @(Model.StockFilter == "out" ? "active" : "")"
           asp-controller="Manager" asp-action="Index" asp-route-tab="stock" asp-route-stockFilter="out">
            Out of stock (@Model.StockItems.Count(s => s.IsOut))
        </a>
    </div>

    <div class="panel panel--flush">
        @if (filteredStock.Any())
        {
            <table class="stock-table">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Category</th>
                        <th class="th-right">Stock</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in filteredStock)
                    {
                        <tr>
                            <td>
                                <div class="stock-name">@item.Name</div>
                                <div class="stock-meta">€@item.Price.ToString("0.00") · @item.Vat% VAT</div>
                            </td>
                            <td class="td-muted">@item.Category</td>
                            <td>
                                <div class="qty-cell">
                                    @if (item.IsLow)
                                    {
                                        <span class="warn-icon">△</span>
                                    }
                                    <div class="stock-qty @(item.IsOut ? "qty-out" : item.IsLow ? "qty-low" : "qty-ok")">
                                        @item.Quantity
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="empty-state">No items match this filter.</p>
        }
    </div>
}

<!-- ── FEEDBACK TAB ── -->
@if (Model.ActiveTab == "feedback")
{
    <div class="fb-summary">
        <div class="fb-stat comment">
            <div class="fb-stat-num">@Model.CommentCount</div>
            <div class="fb-stat-label">Comment</div>
        </div>
        <div class="fb-stat complaint">
            <div class="fb-stat-num">@Model.ComplaintCount</div>
            <div class="fb-stat-label">Complaint</div>
        </div>
        <div class="fb-stat praise">
            <div class="fb-stat-num">@Model.PraiseCount</div>
            <div class="fb-stat-label">Praise</div>
        </div>
    </div>

    @if (Model.FeedbackItems.Any())
    {
        @foreach (var fb in Model.FeedbackItems.OrderByDescending(f => f.CreatedAt))
        {
            string badgeClass = fb.Type.ToLower() switch
            {
                "complaint" => "complaint",
                "praise" => "praise",
                _ => "comment"
            };
            <div class="fb-card">
                <div class="fb-card-top">
                    <div class="flex-row-gap">
                        <span class="fb-badge @badgeClass">@fb.Type</span>
                        <span class="text-meta">Table @fb.TableId</span>
                    </div>
                    <div class="fb-meta">@fb.CreatedAt.ToString("HH:mm") · @fb.Staff</div>
                </div>
                <div class="fb-text">@fb.Text</div>
            </div>
        }
    }
    else
    {
        <p class="empty-state">No feedback yet.</p>
    }
}

<!-- ── ORDERS TAB ── -->
@if (Model.ActiveTab == "orders")
{
    <div class="panel-title">Open tables (@Model.OpenTables.Count)</div>
    @if (Model.OpenTables.Any())
    {
        @foreach (var ot in Model.OpenTables)
        {
            <div class="open-table-row">
                <div class="ot-left">
                    <div class="ot-title">Table @ot.TableId <span class="ot-waiter">@ot.Guests guests · @ot.WaiterName</span></div>
                    <div class="ot-meta">@ot.ItemCount items</div>
                </div>
                <div class="ot-total">€@ot.Total.ToString("0.00")</div>
            </div>
        }
    }
    else
    {
        <p class="empty-state">No open tables.</p>
    }
}
