@model Chapeau.ViewModels.ManagerDashboardViewModel
@{
    ViewData["Title"] = "Manager Dashboard";
    string Tab(string t) => Model.ActiveTab == t ? "tab-btn active" : "tab-btn";

    decimal vat9Total  = Model.Vat9ExclBtw  + Model.Vat9Amount;
    decimal vat21Total = Model.Vat21ExclBtw + Model.Vat21Amount;
    decimal vatExclAll = Model.Vat9ExclBtw  + Model.Vat21ExclBtw;
    decimal vatAmtAll  = Model.Vat9Amount   + Model.Vat21Amount;
    decimal vatInclAll = vat9Total          + vat21Total;

    var filteredStock = Model.StockFilter switch
    {
        "low" => Model.StockItems.Where(s => s.IsLow && !s.IsOut).ToList(),
        "out" => Model.StockItems.Where(s => s.IsOut).ToList(),
        _     => Model.StockItems
    };

    decimal maxRevenue = Model.CategoryRevenues.Any() ? Model.CategoryRevenues.Max(c => c.Amount) : 1;
}

<style>
    .mgr-header {
        display: flex; align-items: center; gap: 16px; margin-bottom: 28px;
    }
    .mgr-header-icon {
        width: 48px; height: 48px; border-radius: 12px;
        background: #7a2a3e; display: flex; align-items: center;
        justify-content: center; font-size: 22px;
    }
    .mgr-header h1 {
        font-size: 26px; font-weight: 700; color: #2a1a1f;
        font-family: Georgia, serif; margin-bottom: 2px;
    }
    .mgr-header p { font-size: 13px; color: #9a8a90; }

    /* Stat cards */
    .stat-grid {
        display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; margin-bottom: 28px;
    }
    .stat-card {
        background: #fff; border: 1px solid #ede8e4;
        border-radius: 14px; padding: 20px;
    }
    .stat-icon {
        width: 36px; height: 36px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 16px; margin-bottom: 12px;
        background: #f5f0eb;
    }
    .stat-value { font-size: 26px; font-weight: 700; color: #2a1a1f; margin-bottom: 4px; }
    .stat-label { font-size: 13px; color: #6b5560; margin-bottom: 4px; }
    .stat-sub   { font-size: 12px; color: #9a8a90; }

    /* Tabs */
    .tab-nav {
        display: flex; gap: 4px; background: #f5f0eb;
        border-radius: 12px; padding: 4px; margin-bottom: 24px;
    }
    .tab-btn {
        flex: 1; padding: 10px; border: none; background: transparent;
        border-radius: 10px; font-size: 13px; font-weight: 600;
        color: #9a8a90; cursor: pointer; text-decoration: none;
        text-align: center; transition: background 0.15s, color 0.15s;
        display: block;
    }
    .tab-btn:hover { color: #2a1a1f; }
    .tab-btn.active { background: #7a2a3e; color: #fff; }

    /* Panel */
    .panel { background: #fff; border: 1px solid #ede8e4; border-radius: 14px; padding: 24px; margin-bottom: 20px; }
    .panel-title { font-size: 18px; font-weight: 700; color: #2a1a1f; margin-bottom: 20px; font-family: Georgia, serif; }

    /* Bar chart */
    .bar-chart { display: flex; flex-direction: column; gap: 12px; }
    .bar-row { display: flex; align-items: center; gap: 12px; }
    .bar-label { width: 120px; font-size: 13px; color: #6b5560; text-align: right; flex-shrink: 0; }
    .bar-track { flex: 1; height: 28px; background: #f5f0eb; border-radius: 6px; overflow: hidden; }
    .bar-fill  { height: 100%; background: #7a2a3e; border-radius: 6px; display: flex; align-items: center; padding-left: 8px; }
    .bar-amount { font-size: 12px; font-weight: 700; color: #fff; white-space: nowrap; }
    .bar-empty { font-size: 12px; color: #c9b8be; padding-left: 8px; }

    /* Staff performance */
    .staff-row {
        display: flex; align-items: center; gap: 12px;
        padding: 12px 0; border-bottom: 1px solid #f0ebe8;
    }
    .staff-row:last-child { border-bottom: none; }
    .staff-av {
        width: 36px; height: 36px; border-radius: 50%;
        background: #7a2a3e; color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-size: 12px; font-weight: 700; flex-shrink: 0;
    }
    .staff-info { flex: 1; }
    .staff-name  { font-size: 14px; font-weight: 600; color: #2a1a1f; }
    .staff-items { font-size: 12px; color: #9a8a90; }
    .staff-revenue { font-size: 14px; font-weight: 700; color: #7a2a3e; }
    .staff-bar-track { height: 4px; background: #f5f0eb; border-radius: 2px; margin-top: 6px; }
    .staff-bar-fill  { height: 100%; background: #7a2a3e; border-radius: 2px; }

    /* VAT table */
    .vat-header { background: #2a1218; border-radius: 10px; padding: 16px 20px; margin-bottom: 16px; }
    .vat-header h3 { font-size: 16px; font-weight: 700; color: #f0e6d8; margin-bottom: 4px; }
    .vat-header p  { font-size: 12px; color: #6b5560; }
    .vat-table { width: 100%; border-collapse: collapse; }
    .vat-table th { font-size: 11px; font-weight: 700; text-transform: uppercase;
                    letter-spacing: 0.08em; color: #9a8a90; padding: 8px 12px;
                    border-bottom: 1px solid #f0ebe8; text-align: left; }
    .vat-table td { padding: 14px 12px; border-bottom: 1px solid #f0ebe8; font-size: 14px; color: #2a1a1f; }
    .vat-table tr:last-child td { font-weight: 700; border-bottom: none; }
    .vat-badge {
        display: inline-block; padding: 2px 8px; border-radius: 20px;
        font-size: 12px; font-weight: 700; color: #fff;
        margin-bottom: 2px;
    }
    .vat-sub { font-size: 11px; color: #9a8a90; }
    .vat-amount { color: #c9843a; }

    /* Pie chart (CSS only) */
    .pie-wrap { display: flex; align-items: center; justify-content: center; gap: 40px; padding: 20px 0; }
    .pie { width: 120px; height: 120px; border-radius: 50%; background: #7a2a3e; flex-shrink: 0; }
    .pie-legend { display: flex; flex-direction: column; gap: 8px; }
    .pie-legend-item { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #6b5560; }
    .pie-dot { width: 12px; height: 12px; border-radius: 3px; }

    /* Stock */
    .filter-pills { display: flex; gap: 8px; margin-bottom: 20px; }
    .pill {
        padding: 6px 16px; border-radius: 20px; font-size: 13px; font-weight: 600;
        text-decoration: none; border: 1px solid #ede8e4; background: #fff; color: #6b5560;
        transition: background 0.15s;
    }
    .pill.active { background: #7a2a3e; color: #fff; border-color: #7a2a3e; }
    .stock-table { width: 100%; border-collapse: collapse; }
    .stock-table th { font-size: 11px; font-weight: 700; text-transform: uppercase;
                      letter-spacing: 0.08em; color: #9a8a90; padding: 8px 12px;
                      border-bottom: 1px solid #f0ebe8; text-align: left; }
    .stock-table td { padding: 12px 12px; border-bottom: 1px solid #f0ebe8; font-size: 14px; color: #2a1a1f; }
    .stock-table tr:last-child td { border-bottom: none; }
    .stock-name { font-weight: 600; margin-bottom: 2px; }
    .stock-meta { font-size: 12px; color: #9a8a90; }
    .stock-qty {
        width: 32px; height: 32px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 13px; font-weight: 700; color: #fff;
        margin-left: auto;
    }
    .qty-ok  { background: #3db87a; }
    .qty-low { background: #e87d3e; }
    .qty-out { background: #9a8a90; }
    .qty-cell { text-align: right; display: flex; align-items: center; justify-content: flex-end; gap: 8px; }
    .warn-icon { color: #e87d3e; font-size: 16px; }

    /* Feedback */
    .fb-summary { display: grid; grid-template-columns: repeat(3,1fr); gap: 12px; margin-bottom: 20px; }
    .fb-stat { border-radius: 12px; padding: 20px; text-align: center; }
    .fb-stat.comment  { background: #f0f5f0; }
    .fb-stat.complaint { background: #fff0f0; }
    .fb-stat.praise   { background: #f5f5f0; }
    .fb-stat-num  { font-size: 28px; font-weight: 700; color: #2a1a1f; }
    .fb-stat-label { font-size: 13px; }
    .fb-stat.comment  .fb-stat-label { color: #3db87a; }
    .fb-stat.complaint .fb-stat-label { color: #e87d3e; }
    .fb-stat.praise   .fb-stat-label { color: #6b5560; }
    .fb-card {
        border-left: 4px solid; border-radius: 0 10px 10px 0;
        padding: 14px 16px; margin-bottom: 10px; background: #fff;
        border: 1px solid #f0ebe8; border-radius: 10px;
    }
    .fb-card-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
    .fb-badge {
        padding: 2px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; color: #fff;
    }
    .fb-badge.praise   { background: #3db87a; }
    .fb-badge.complaint { background: #e87d3e; }
    .fb-badge.comment  { background: #5a7abf; }
    .fb-meta { font-size: 12px; color: #9a8a90; }
    .fb-text { font-size: 14px; color: #2a1a1f; }

    /* Orders */
    .open-table-row {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 20px; background: #fff8f3;
        border: 1px solid #f0d8c0; border-radius: 12px; margin-bottom: 10px;
    }
    .ot-left { display: flex; flex-direction: column; gap: 4px; }
    .ot-title { font-size: 15px; font-weight: 700; color: #2a1a1f; }
    .ot-meta  { font-size: 12px; color: #9a8a90; }
    .ot-total { font-size: 16px; font-weight: 700; color: #7a2a3e; }
    .empty-state { text-align: center; color: #9a8a90; padding: 40px; font-size: 14px; }
</style>

<!-- Header -->
<div class="mgr-header">
    <div class="mgr-header-icon">📊</div>
    <div>
        <h1>Manager Dashboard</h1>
        <p>Restaurant Chapeau · @DateTime.Now.ToString("dddd d MMMM")</p>
    </div>
</div>

<!-- Stat cards -->
<div class="stat-grid">
    <div class="stat-card">
        <div class="stat-icon">€</div>
        <div class="stat-value">€@Model.RevenuePaid.ToString("0.00")</div>
        <div class="stat-label">Revenue (paid)</div>
        <div class="stat-sub">+ €@Model.RevenueOpen.ToString("0.00") open</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">👥</div>
        <div class="stat-value">@Model.CoversToday</div>
        <div class="stat-label">Covers today</div>
        <div class="stat-sub">@Model.CoversSeated at table</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">📈</div>
        <div class="stat-value">€@Model.TipsReceived.ToString("0.00")</div>
        <div class="stat-label">Tips received</div>
        <div class="stat-sub">@Model.TablesCheckedOut tables checked out</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">📦</div>
        <div class="stat-value">@(Model.StockOutCount + Model.StockLowCount)</div>
        <div class="stat-label">Stock warnings</div>
        <div class="stat-sub">@Model.StockOutCount out · @Model.StockLowCount low</div>
    </div>
</div>

<!-- Tab nav -->
<div class="tab-nav">
    <a class="@Tab("revenue")"  asp-controller="Manager" asp-action="Index" asp-route-tab="revenue">Revenue</a>
    <a class="@Tab("vat")"      asp-controller="Manager" asp-action="Index" asp-route-tab="vat">VAT</a>
    <a class="@Tab("stock")"    asp-controller="Manager" asp-action="Index" asp-route-tab="stock">Stock</a>
    <a class="@Tab("feedback")" asp-controller="Manager" asp-action="Index" asp-route-tab="feedback">Feedback</a>
    <a class="@Tab("orders")"   asp-controller="Manager" asp-action="Index" asp-route-tab="orders">Orders</a>
</div>

<!-- ── REVENUE TAB ── -->
@if (Model.ActiveTab == "revenue")
{
    <div class="panel">
        <div class="panel-title">Revenue by category</div>
        @if (Model.CategoryRevenues.Any())
        {
            <div class="bar-chart">
                @foreach (var cat in Model.CategoryRevenues.OrderByDescending(c => c.Amount))
                {
                    int pct = (int)(cat.Amount / maxRevenue * 100);
                    <div class="bar-row">
                        <div class="bar-label">@cat.Category</div>
                        <div class="bar-track">
                            @if (pct > 0)
                            {
                                <div class="bar-fill" style="width:@pct%">
                                    <span class="bar-amount">€@cat.Amount.ToString("0.00")</span>
                                </div>
                            }
                            else
                            {
                                <span class="bar-empty">€0.00</span>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="empty-state">No revenue data yet.</p>
        }
    </div>

    <div class="panel">
        <div class="panel-title">Staff performance</div>
        @if (Model.StaffPerformances.Any())
        {
            decimal maxStaffRev = Model.StaffPerformances.Max(s => s.Revenue);
            @foreach (var s in Model.StaffPerformances.OrderByDescending(s => s.Revenue))
            {
                int pct = maxStaffRev > 0 ? (int)(s.Revenue / maxStaffRev * 100) : 0;
                <div class="staff-row">
                    <div class="staff-av">@s.Initials</div>
                    <div class="staff-info">
                        <div class="staff-name">@s.Name</div>
                        <div class="staff-items">@s.Items items ordered</div>
                        <div class="staff-bar-track">
                            <div class="staff-bar-fill" style="width:@pct%"></div>
                        </div>
                    </div>
                    <div class="staff-revenue">€@s.Revenue.ToString("0.00")</div>
                </div>
            }
        }
        else
        {
            <p class="empty-state">No staff data yet.</p>
        }
    </div>
}

<!-- ── VAT TAB ── -->
@if (Model.ActiveTab == "vat")
{
    <div class="panel">
        <div class="vat-header">
            <h3>VAT specification</h3>
            <p>All orders today (open + paid)</p>
        </div>
        <table class="vat-table">
            <thead>
                <tr>
                    <th>Rate</th>
                    <th>Excl. VAT</th>
                    <th>VAT</th>
                    <th>Incl. VAT</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>
                        <div><span class="vat-badge" style="background:#7a2a3e">9%</span></div>
                        <div class="vat-sub">Food &amp; soft drinks</div>
                    </td>
                    <td>€@Model.Vat9ExclBtw.ToString("0.00")</td>
                    <td class="vat-amount">€@Model.Vat9Amount.ToString("0.00")</td>
                    <td>€@vat9Total.ToString("0.00")</td>
                </tr>
                <tr>
                    <td>
                        <div><span class="vat-badge" style="background:#2a4f7a">21%</span></div>
                        <div class="vat-sub">Alcohol</div>
                    </td>
                    <td>€@Model.Vat21ExclBtw.ToString("0.00")</td>
                    <td class="vat-amount">€@Model.Vat21Amount.ToString("0.00")</td>
                    <td>€@vat21Total.ToString("0.00")</td>
                </tr>
                <tr>
                    <td>Total</td>
                    <td>€@vatExclAll.ToString("0.00")</td>
                    <td class="vat-amount">€@vatAmtAll.ToString("0.00")</td>
                    <td>€@vatInclAll.ToString("0.00")</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="panel">
        <div class="panel-title">VAT distribution</div>
        <div class="pie-wrap">
            <div class="pie"></div>
            <div class="pie-legend">
                <div class="pie-legend-item">
                    <div class="pie-dot" style="background:#7a2a3e"></div>
                    VAT 9% (food/soft drinks): €@Model.Vat9Amount.ToString("0.00")
                </div>
                <div class="pie-legend-item">
                    <div class="pie-dot" style="background:#2a4f7a"></div>
                    VAT 21% (alcohol): €@Model.Vat21Amount.ToString("0.00")
                </div>
            </div>
        </div>
    </div>
}

<!-- ── STOCK TAB ── -->
@if (Model.ActiveTab == "stock")
{
    <div class="filter-pills">
        <a class="pill @(Model.StockFilter == "all" ? "active" : "")"
           asp-controller="Manager" asp-action="Index" asp-route-tab="stock" asp-route-stockFilter="all">
            All (@Model.StockItems.Count)
        </a>
        <a class="pill @(Model.StockFilter == "low" ? "active" : "")"
           asp-controller="Manager" asp-action="Index" asp-route-tab="stock" asp-route-stockFilter="low">
            Low (@Model.StockItems.Count(s => s.IsLow && !s.IsOut))
        </a>
        <a class="pill @(Model.StockFilter == "out" ? "active" : "")"
           asp-controller="Manager" asp-action="Index" asp-route-tab="stock" asp-route-stockFilter="out">
            Out of stock (@Model.StockItems.Count(s => s.IsOut))
        </a>
    </div>

    <div class="panel" style="padding:0;overflow:hidden">
        @if (filteredStock.Any())
        {
            <table class="stock-table">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Category</th>
                        <th style="text-align:right">Stock</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in filteredStock)
                    {
                        <tr>
                            <td>
                                <div class="stock-name">@item.Name</div>
                                <div class="stock-meta">€@item.Price.ToString("0.00") · @item.Vat% VAT</div>
                            </td>
                            <td style="color:#9a8a90">@item.Category</td>
                            <td>
                                <div class="qty-cell">
                                    @if (item.IsLow) { <span class="warn-icon">△</span> }
                                    <div class="stock-qty @(item.IsOut ? "qty-out" : item.IsLow ? "qty-low" : "qty-ok")">
                                        @item.Quantity
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="empty-state">No items match this filter.</p>
        }
    </div>
}

<!-- ── FEEDBACK TAB ── -->
@if (Model.ActiveTab == "feedback")
{
    <div class="fb-summary">
        <div class="fb-stat comment">
            <div class="fb-stat-num">@Model.CommentCount</div>
            <div class="fb-stat-label">Comment</div>
        </div>
        <div class="fb-stat complaint">
            <div class="fb-stat-num">@Model.ComplaintCount</div>
            <div class="fb-stat-label">Complaint</div>
        </div>
        <div class="fb-stat praise">
            <div class="fb-stat-num">@Model.PraiseCount</div>
            <div class="fb-stat-label">Praise</div>
        </div>
    </div>

    @if (Model.FeedbackItems.Any())
    {
        @foreach (var fb in Model.FeedbackItems.OrderByDescending(f => f.CreatedAt))
        {
            string badgeClass = fb.Type.ToLower() switch
            {
                "complaint" => "complaint",
                "praise"    => "praise",
                _           => "comment"
            };
            <div class="fb-card">
                <div class="fb-card-top">
                    <div style="display:flex;gap:10px;align-items:center">
                        <span class="fb-badge @badgeClass">@fb.Type</span>
                        <span style="font-size:13px;color:#9a8a90">Table @fb.TableId</span>
                    </div>
                    <div class="fb-meta">@fb.CreatedAt.ToString("HH:mm") · @fb.Staff</div>
                </div>
                <div class="fb-text">@fb.Text</div>
            </div>
        }
    }
    else
    {
        <p class="empty-state">No feedback yet.</p>
    }
}

<!-- ── ORDERS TAB ── -->
@if (Model.ActiveTab == "orders")
{
    <div class="panel-title">Open tables (@Model.OpenTables.Count)</div>
    @if (Model.OpenTables.Any())
    {
        @foreach (var ot in Model.OpenTables)
        {
            <div class="open-table-row">
                <div class="ot-left">
                    <div class="ot-title">Table @ot.TableId <span style="font-weight:400;font-size:13px;color:#9a8a90">@ot.Guests guests · @ot.WaiterName</span></div>
                    <div class="ot-meta">@ot.ItemCount items</div>
                </div>
                <div class="ot-total">€@ot.Total.ToString("0.00")</div>
            </div>
        }
    }
    else
    {
        <p class="empty-state">No open tables.</p>
    }
}
