@model Chapeau.Models.Staff
@{
    ViewData["Title"] = "Edit Staff";
}

<div class="card-form">
    <h1>Edit Staff Member</h1>
    <form method="post" asp-controller="Manager" asp-action="UpdateStaff">
        <input type="hidden" name="id" value="@Model.StaffId" />
        <div class="form-row">
            <div class="form-group">
                <label>Full Name</label>
                <input type="text" name="name" value="@Model.Name" required />
            </div>
            <div class="form-group">
                <label>Role</label>
                <select name="role">
                    <option value="Manager" selected="@(Model.Role == Chapeau.Models.Enums.StaffRole.Manager)">Manager</option>
                    <option value="Chef" selected="@(Model.Role == Chapeau.Models.Enums.StaffRole.Chef)">Chef</option>
                    <option value="Bar" selected="@(Model.Role == Chapeau.Models.Enums.StaffRole.Bar)">Bar</option>
                    <option value="Waiter" selected="@(Model.Role == Chapeau.Models.Enums.StaffRole.Waiter)">Waiter</option>
                </select>
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>New PIN</label>
                <input type="password" name="pin" placeholder="Leave blank to keep current" />
                <span class="pin-hint">Leave blank to keep existing PIN.</span>
            </div>
        </div>
        <div class="btn-row">
            <button type="submit" class="btn-save">Save Changes</button>
            <a class="btn-cancel" asp-controller="Manager" asp-action="StaffManagement">Cancel</a>
        </div>
    </form>
</div>
