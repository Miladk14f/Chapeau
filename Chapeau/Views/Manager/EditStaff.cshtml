@model Chapeau.Models.Staff
@{
    ViewData["Title"] = "Edit Staff";
}

<style>
    .card-form {
        background: #fff; border: 1px solid #ede8e4; border-radius: 14px;
        padding: 28px; max-width: 560px;
    }
    .card-form h1 {
        font-size: 22px; font-weight: 700; color: #2a1a1f;
        font-family: Georgia, serif; margin-bottom: 24px;
    }
    .form-row { display: flex; gap: 16px; margin-bottom: 16px; flex-wrap: wrap; }
    .form-group { display: flex; flex-direction: column; gap: 6px; flex: 1; min-width: 160px; }
    .form-group label {
        font-size: 11px; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.08em; color: #9a8a90;
    }
    .form-group input, .form-group select {
        padding: 10px 12px; border: 1px solid #ede8e4; border-radius: 8px;
        font-size: 14px; color: #2a1a1f; background: #faf7f5; outline: none;
    }
    .form-group input:focus, .form-group select:focus { border-color: #7a2a3e; }
    .pin-hint { font-size: 11px; color: #9a8a90; margin-top: 4px; }
    .btn-row { display: flex; gap: 12px; margin-top: 8px; }
    .btn-save {
        padding: 10px 24px; background: #7a2a3e; color: #fff;
        border: none; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer;
    }
    .btn-save:hover { background: #8e3349; }
    .btn-cancel {
        padding: 10px 20px; background: #f5f0eb; border: 1px solid #ede8e4;
        border-radius: 8px; font-size: 14px; font-weight: 600;
        color: #2a1a1f; text-decoration: none;
    }
</style>

<div class="card-form">
    <h1>Edit Staff Member</h1>
    <form method="post" asp-controller="Manager" asp-action="UpdateStaff">
        <input type="hidden" name="id" value="@Model.Id" />
        <div class="form-row">
            <div class="form-group">
                <label>Full Name</label>
                <input type="text" name="name" value="@Model.Name" required />
            </div>
            <div class="form-group">
                <label>Role</label>
                <select name="role">
                    <option value="Manager" selected="@(Model.Role == Chapeau.Models.Enums.EStaffRole.Manager)">Manager</option>
                    <option value="Chef"    selected="@(Model.Role == Chapeau.Models.Enums.EStaffRole.Chef)">Chef</option>
                    <option value="Bar"     selected="@(Model.Role == Chapeau.Models.Enums.EStaffRole.Bar)">Bar</option>
                    <option value="Waiter"  selected="@(Model.Role == Chapeau.Models.Enums.EStaffRole.Waiter)">Waiter</option>
                </select>
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>New PIN</label>
                <input type="password" name="pin" placeholder="Leave blank to keep current" />
                <span class="pin-hint">Leave blank to keep existing PIN.</span>
            </div>
        </div>
        <div class="btn-row">
            <button type="submit" class="btn-save">Save Changes</button>
            <a class="btn-cancel" asp-controller="Manager" asp-action="StaffManagement">Cancel</a>
        </div>
    </form>
</div>
