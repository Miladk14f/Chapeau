@model List<Chapeau.Models.Staff>
@using Chapeau.Models.Enums
@{
    ViewData["Title"] = "Staff Management";
}

<div class="sm-header">
    <h1>Staff Management</h1>
    <a asp-controller="Manager" asp-action="Index" class="link-muted">← Dashboard</a>
</div>

<table class="staff-table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Role</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            string initials = string.Concat(s.Name.Split(' ').Where(w => w.Length > 0).Take(2).Select(w => w[0].ToString().ToUpper()));
            string roleClass = s.Role switch
            {
                StaffRole.Manager => "role-manager",
                StaffRole.Chef => "role-chef",
                StaffRole.Bar => "role-bar",
                _ => "role-waiter"
            };
            <tr>
                <td>
                    <span class="avatar-sm">@initials</span>
                    @s.Name
                </td>
                <td>
                    <span class="role-badge @roleClass">@s.Role</span>
                </td>
                <td>
                    <a class="btn-edit" asp-controller="Manager" asp-action="EditStaff" asp-route-id="@s.StaffId">Edit</a>
                    <form method="post" asp-controller="Manager" asp-action="DeleteStaff" class="form-inline">
                        <input type="hidden" name="id" value="@s.StaffId" />
                        <button type="submit" class="btn-delete">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="card-form">
    <h2>Add New Staff</h2>
    <form method="post" asp-controller="Manager" asp-action="CreateStaff">
        <div class="form-row">
            <div class="form-group">
                <label>Full Name</label>
                <input type="text" name="name" placeholder="e.g. Sophie Martin" required />
            </div>
            <div class="form-group">
                <label>Role</label>
                <select name="role">
                    <option value="Manager">Manager</option>
                    <option value="Chef">Chef</option>
                    <option value="Bar">Bar</option>
                    <option value="Waiter">Waiter</option>
                </select>
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>PIN</label>
                <input type="password" name="pin" placeholder="Enter PIN" required />
            </div>
        </div>
        <button type="submit" class="btn-primary">+ Add Staff Member</button>
    </form>
</div>
