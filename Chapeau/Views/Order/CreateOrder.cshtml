    @* Views/Orders/Create.cshtml *@

    @model Chapeau.ViewModels.OrderViewModel;

    @{
        ViewData["Title"] = "Create Order";
    }

    <style>
        .order-page {
            display: flex;
            gap: 20px;
            margin-top: 20px;
        }

        .panel {
            flex: 1;
            border: 1px solid #ccc;
            padding: 15px;
        }

            .panel h2 {
                margin-top: 0;
            }

        .category-buttons {
            margin-bottom: 15px;
        }

            .category-buttons button {
                margin-right: 5px;
            }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

        table, th, td {
            border: 1px solid #ccc;
        }

        th, td {
            padding: 8px;
            text-align: left;
        }

        .actions button {
            margin-right: 5px;
        }

        .send-button {
            margin-top: 20px;
            width: 100%;
            padding: 10px;
        }
    </style>

    <div class="order-page">

        <!-- LEFT SIDE - MENU ITEMS -->
        <div class="panel">

            <h2>Menu Items</h2>

            <!-- Categories -->
            <div class="category-buttons">
                <button type="button">Starters</button>
                <button type="button">Mains</button>
                <button type="button">Drinks</button>
                <button type="button">Desserts</button>
            </div>

            <!-- Menu Items Table -->
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Price</th>
                        <th>Add</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model.MenuItems)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.Price.ToString("0.00")</td>
                            <td>
                                <form asp-action="AddItem" method="post">
                                    <input type="hidden" name="menuItemId" value="@item.MenuItemId" />
                                    <input type="hidden" name="tableId" value="@Model.TableOrder.TableId" />


                                    <button type="submit">+</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>


        <!-- RIGHT SIDE - ORDER ITEMS -->
        <div class="panel">

            <h2>Order - Table #@Model.TableOrder.TableId</h2>

            <!-- Order Items Table -->
            <table>
                <thead>
                    <tr>
                        <th>Actions</th>
                        <th>Item</th>
                        <th>Quantity</th>
                        <th>Price</th>
                        <th>Delete</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var orderItem in Model.OrderItems)
                    {
                        <tr>

                            <!-- Quantity Actions -->
                            <td class="actions">

                                <!-- Increase -->
                                <form asp-action="AddItem" method="post" style="display:inline;">
                                    <input type="hidden" name="MenuItemId" value="@orderItem.MenuItem.MenuItemId" />
                                    <input type="hidden" name="tableId" value="@Model.TableOrder.TableId" />
                                    <button type="submit">+</button>
                                </form>

                                <!-- Decrease -->
                                <form asp-action="DecreaseItem" method="post" style="display:inline;">
                                    <input type="hidden" name="orderItemId" value="@orderItem.OrderItemId" /> 
                                    @* skf *@
                                    <input type="hidden" name="tableId" value="@Model.TableOrder.TableId" />
                                    <button type="submit">-</button>
                                </form>

                            </td>

                            <td>@orderItem.Name</td>

                            <td>@orderItem.Qty</td>

                            <td>
                                @((orderItem.Price * orderItem.Qty).ToString("0.00"))
                            </td>

                            <!-- Delete -->
                            <td>
                                <form asp-action="DeleteItem" method="post">
                                    <input type="hidden" name="orderItemId" value="@orderItem.OrderItemId" />
                                    <input type="hidden" name="tableId" value="@Model.TableOrder.TableId" />

                                    <button type="submit">X</button>
                                </form>
                            </td>

                        </tr>
                    }
                </tbody>
            </table>

        </div>

    </div>