@model Chapeau.ViewModels.OrderViewModel;

@{
    ViewData["Title"] = "Create Order";
    decimal orderTotal = Model.OrderItems.Sum(i => i.Price * i.Qty);
    int orderCount = Model.OrderItems.Sum(i => i.Qty);
}

<style>
    .order-header {
        display: flex; align-items: center; gap: 16px; margin-bottom: 24px;
    }
    .order-header-left { display: flex; align-items: center; gap: 16px; flex: 1; }
    .order-header-icon {
        width: 48px; height: 48px; border-radius: 14px;
        background: #7a2a3e; display: flex; align-items: center;
        justify-content: center; font-size: 22px;
    }
    .order-header h1 {
        font-size: 26px; font-weight: 700; color: #2a1a1f;
        font-family: Georgia, serif; margin-bottom: 2px;
    }
    .order-header p { font-size: 13px; color: #9a8a90; }
    .btn-close {
        width: 40px; height: 40px; border-radius: 50%;
        border: 1px solid #e0d8d0; background: #fff;
        display: flex; align-items: center; justify-content: center;
        text-decoration: none; color: #6b5560; font-size: 20px;
        transition: all 0.15s; flex-shrink: 0;
    }
    .btn-close:hover { background: #fff0f0; border-color: #f0d0d0; color: #d94040; }

    .order-page {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        align-items: start;
    }
    .panel {
        background: #fff;
        border: 1px solid #ede8e4;
        border-radius: 16px;
        padding: 24px;
    }
    .panel h2 {
        font-size: 18px; font-weight: 700; color: #2a1a1f;
        font-family: Georgia, serif; margin-bottom: 18px;
    }

    .category-buttons {
        display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px;
    }
    .category-buttons button {
        padding: 8px 18px; border-radius: 22px;
        border: 1px solid #ede8e4; background: #f5f0eb;
        font-size: 13px; font-weight: 600; color: #6b5560;
        cursor: pointer; transition: all 0.15s;
    }
    .category-buttons button:hover {
        border-color: #7a2a3e; color: #7a2a3e;
    }

    .menu-row {
        display: flex; align-items: center; justify-content: space-between;
        padding: 12px 0; border-bottom: 1px solid #f0ebe8;
    }
    .menu-row:last-child { border-bottom: none; }
    .menu-info { display: flex; flex-direction: column; gap: 2px; }
    .menu-name { font-size: 14px; font-weight: 600; color: #2a1a1f; }
    .menu-price { font-size: 13px; color: #9a8a90; }
    .menu-row form { margin: 0; }
    .btn-add {
        width: 36px; height: 36px; border-radius: 10px;
        background: #2a5c3a; color: #fff; border: none;
        font-size: 20px; font-weight: 700; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
    }
    .btn-add:hover { background: #1e4a2e; }

    .order-row {
        display: flex; align-items: center; gap: 12px;
        padding: 12px 0; border-bottom: 1px solid #f0ebe8;
    }
    .order-row:last-child { border-bottom: none; }
    .qty-ctrl { display: flex; align-items: center; gap: 6px; }
    .qty-ctrl form { margin: 0; }
    .btn-qty {
        width: 28px; height: 28px; border-radius: 8px;
        border: 1px solid #ede8e4; background: #f5f0eb;
        font-size: 16px; font-weight: 700; color: #6b5560;
        cursor: pointer; display: flex; align-items: center; justify-content: center;
    }
    .btn-qty:hover { background: #e8e0da; }
    .qty-num {
        min-width: 28px; text-align: center;
        font-size: 14px; font-weight: 700; color: #2a1a1f;
    }
    .order-item-info { flex: 1; display: flex; flex-direction: column; gap: 6px; }
    .order-item-name { font-size: 14px; font-weight: 600; color: #2a1a1f; }
    .note-form { display: flex; align-items: center; gap: 6px; margin: 0; }
    .note-input {
        flex: 1; padding: 6px 10px;
        border: 1px solid #e0d8d0; border-radius: 8px;
        font-size: 12px; background: #faf8f6; min-width: 0;
    }
    .note-input:focus { outline: none; border-color: #7a2a3e; }
    .btn-note-save {
        padding: 6px 12px; border-radius: 8px;
        background: #f5f0eb; border: 1px solid #e0d8d0;
        font-size: 12px; font-weight: 600; color: #6b5560; cursor: pointer;
    }
    .btn-note-save:hover { background: #7a2a3e; border-color: #7a2a3e; color: #fff; }
    .order-item-price { font-size: 14px; font-weight: 700; color: #7a2a3e; min-width: 64px; text-align: right; }
    .btn-del {
        width: 28px; height: 28px; border-radius: 8px;
        background: #fff; border: 1px solid #f0d0d0; color: #d94040;
        font-size: 13px; font-weight: 700; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
    }
    .btn-del:hover { background: #fff0f0; }

    .order-empty {
        text-align: center; color: #9a8a90;
        padding: 40px 0; font-size: 14px;
    }

    /* Status cards */
    .status-label {
        display: flex; align-items: center; gap: 6px;
        font-size: 12px; font-weight: 700; letter-spacing: 0.06em;
        text-transform: uppercase; margin: 16px 0 8px;
    }
    .status-label.ready  { color: #2a8c4a; }
    .status-label.served { color: #9a8a90; }

    .status-card {
        display: flex; align-items: center; justify-content: space-between;
        padding: 14px 16px; border-radius: 12px; margin-bottom: 8px;
        border: 1px solid;
    }
    .status-card.ready  { background: #f0faf3; border-color: #b8e6c8; }
    .status-card.served { background: #f7f5f3; border-color: #ece6e2; }
    .status-card-name { font-size: 14px; font-weight: 600; color: #2a1a1f; }
    .status-card.served .status-card-name { color: #9a8a90; }
    .status-card-price { font-size: 14px; font-weight: 700; color: #9a8a90; }
    .status-card-note { font-size: 12px; color: #9a8a90; font-style: italic; margin-top: 2px; }

    .btn-served {
        padding: 8px 18px; border-radius: 10px;
        background: #2a8c4a; color: #fff; border: none;
        font-size: 13px; font-weight: 700; cursor: pointer;
    }
    .btn-served:hover { background: #1f7038; }
    .status-card form { margin: 0; }
    .order-total {
        display: flex; align-items: center; justify-content: space-between;
        margin-top: 18px; padding-top: 18px; border-top: 2px solid #ede8e4;
    }
    .order-total-label { font-size: 15px; font-weight: 700; color: #2a1a1f; }
    .order-total-amount { font-size: 22px; font-weight: 700; color: #7a2a3e; font-family: Georgia, serif; }
</style>

<div class="order-header">
    <div class="order-header-left">
        <div class="order-header-icon">🍽</div>
        <div>
            <h1>New Order</h1>
            <p>Table @Model.TableOrder.TableId · @Model.StaffOrder?.Name</p>
        </div>
    </div>
    <a class="btn-close" asp-controller="RestaurantTable" asp-action="Index" title="Back to tables">✕</a>
</div>

<div class="order-page">

    <!-- LEFT SIDE - MENU ITEMS -->
    <div class="panel">
        <h2>Menu Items</h2>

        <div class="category-buttons">
            <button type="button">Starters</button>
            <button type="button">Mains</button>
            <button type="button">Drinks</button>
            <button type="button">Desserts</button>
        </div>

        @foreach (var item in Model.MenuItems)
        {
            <div class="menu-row">
                <div class="menu-info">
                    <span class="menu-name">@item.Name</span>
                    <span class="menu-price">€@item.Price.ToString("0.00")</span>
                </div>
                <form asp-action="AddItem" method="post">
                    <input type="hidden" name="menuItemId" value="@item.MenuItemId" />
                    <input type="hidden" name="tableId" value="@Model.TableOrder.TableId" />
                    <button type="submit" class="btn-add">+</button>
                </form>
            </div>
        }
    </div>

    <!-- RIGHT SIDE - ORDER ITEMS -->
    <div class="panel">
        <h2>Order · Table @Model.TableOrder.TableId</h2>

        @if (Model.OrderItems.Any())
        {
            var orderedItems = Model.OrderItems.Where(i => i.Status == Chapeau.Models.Enums.OrderItemStatus.Ordered).ToList();
            var readyItems   = Model.OrderItems.Where(i => i.Status == Chapeau.Models.Enums.OrderItemStatus.Ready).ToList();
            var servedItems  = Model.OrderItems.Where(i => i.Status == Chapeau.Models.Enums.OrderItemStatus.Served).ToList();

            @foreach (var orderItem in orderedItems)
            {
                <div class="order-row">
                    <div class="qty-ctrl">
                        <form asp-action="DecreaseItem" method="post">
                            <input type="hidden" name="orderItemId" value="@orderItem.OrderItemId" />
                            <input type="hidden" name="tableId" value="@Model.TableOrder.TableId" />
                            <button type="submit" class="btn-qty">−</button>
                        </form>
                        <span class="qty-num">@orderItem.Qty</span>
                        <form asp-action="AddItem" method="post">
                            <input type="hidden" name="MenuItemId" value="@orderItem.MenuItem.MenuItemId" />
                            <input type="hidden" name="tableId" value="@Model.TableOrder.TableId" />
                            <button type="submit" class="btn-qty">+</button>
                        </form>
                    </div>

                    <div class="order-item-info">
                        <span class="order-item-name">@orderItem.Name</span>
                        <form asp-action="UpdateItemNote" method="post" class="note-form">
                            <input type="hidden" name="orderItemId" value="@orderItem.OrderItemId" />
                            <input type="hidden" name="tableId" value="@Model.TableOrder.TableId" />
                            <input type="text" name="note" class="note-input" placeholder="Add note…" value="@orderItem.Note" />
                            <button type="submit" class="btn-note-save">Save</button>
                        </form>
                    </div>
                    <span class="order-item-price">€@((orderItem.Price * orderItem.Qty).ToString("0.00"))</span>

                    <form asp-action="DeleteItem" method="post">
                        <input type="hidden" name="orderItemId" value="@orderItem.OrderItemId" />
                        <input type="hidden" name="tableId" value="@Model.TableOrder.TableId" />
                        <button type="submit" class="btn-del">✕</button>
                    </form>
                </div>
            }

            @if (readyItems.Any())
            {
                <div class="status-label ready">✓ Ready to serve</div>
                @foreach (var item in readyItems)
                {
                    <div class="status-card ready">
                        <div>
                            <span class="status-card-name">@item.Qty× @item.Name</span>
                            @if (!string.IsNullOrEmpty(item.Note))
                            {
                                <div class="status-card-note">📝 @item.Note</div>
                            }
                        </div>
                        <form asp-action="ServeItem" method="post">
                            <input type="hidden" name="orderItemId" value="@item.OrderItemId" />
                            <input type="hidden" name="tableId" value="@Model.TableOrder.TableId" />
                            <button type="submit" class="btn-served">Served</button>
                        </form>
                    </div>
                }
            }

            @if (servedItems.Any())
            {
                <div class="status-label served">✓ Served</div>
                @foreach (var item in servedItems)
                {
                    <div class="status-card served">
                        <div>
                            <span class="status-card-name">@item.Qty× @item.Name</span>
                            @if (!string.IsNullOrEmpty(item.Note))
                            {
                                <div class="status-card-note">📝 @item.Note</div>
                            }
                        </div>
                        <span class="status-card-price">€@((item.Price * item.Qty).ToString("0.00"))</span>
                    </div>
                }
            }

            <div class="order-total">
                <span class="order-total-label">Total (@orderCount items)</span>
                <span class="order-total-amount">€@orderTotal.ToString("0.00")</span>
            </div>
        }
        else
        {
            <div class="order-empty">No items yet. Add from the menu.</div>
        }
    </div>

</div>
