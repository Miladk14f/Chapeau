@model Chapeau.ViewModels.OrderViewModel;

@{
    ViewData["Title"] = "Create Order";
    decimal orderTotal = Model.OrderItems.Sum(i => i.Price * i.Qty);
    int orderCount = Model.OrderItems.Sum(i => i.Qty);
}


<div class="order-header">
    <div class="order-header-left">
        <div class="order-header-icon">🍽</div>
        <div>
            <h1>New Order</h1>
            <p>Table @Model.TableOrder.TableId · @Model.StaffOrder?.Name</p>
        </div>
    </div>
    <div class="order-header-actions">
        <a class="btn-bill" asp-controller="Payment" asp-action="Index" asp-route-tableId="@Model.TableOrder.TableId">🧾 Bill</a>
        <a class="btn-close" asp-controller="RestaurantTable" asp-action="Index" title="Back to tables">✕</a>
    </div>
</div>

<div class="order-page">

    <!-- LEFT SIDE - MENU ITEMS -->
    <div class="panel">
        <h2>Menu Items</h2>

        <div class="category-buttons">
            <button type="button" class="active" onclick="filterMenu('', this)">All</button>
            @{
                var seenCats = new System.Collections.Generic.HashSet<string>();
            }
            @foreach (var item in Model.MenuItems)
            {
                if (!string.IsNullOrEmpty(item.CategoryDisplayName) && seenCats.Add(item.CategoryDisplayName))
                {
                    <button type="button" onclick="filterMenu('@item.CategoryDisplayName', this)">@item.CategoryDisplayName</button>
                }
            }
        </div>

        <div id="menu-list">
        @foreach (var item in Model.MenuItems)
        {
            <div class="menu-row" data-category="@item.CategoryDisplayName">
                <div class="menu-info">
                    <span class="menu-name">@item.Name</span>
                    <span class="menu-price">€@item.Price.ToString("0.00")</span>
                </div>
                <form asp-action="AddItem" method="post">
                    <input type="hidden" name="menuItemId" value="@item.MenuItemId" />
                    <input type="hidden" name="tableId" value="@Model.TableOrder.TableId" />
                    <button type="submit" class="btn-add">+</button>
                </form>
            </div>
        }
        </div>

        <script>
        var FILTER_KEY = 'orderMenuFilter_@Model.TableOrder.TableId';

        function filterMenu(cat, btn) {
            sessionStorage.setItem(FILTER_KEY, cat);
            document.querySelectorAll('.category-buttons button').forEach(function(b) { b.classList.remove('active'); });
            btn.classList.add('active');
            document.querySelectorAll('#menu-list .menu-row').forEach(function(row) {
                row.style.display = (!cat || row.dataset.category === cat) ? '' : 'none';
            });
        }

        (function restoreFilter() {
            var saved = sessionStorage.getItem(FILTER_KEY);
            if (!saved) return;
            var btn = Array.from(document.querySelectorAll('.category-buttons button'))
                          .find(function(b) { return b.textContent.trim() === saved; });
            if (btn) filterMenu(saved, btn);
        })();
        </script>
    </div>

    <!-- RIGHT SIDE - ORDER ITEMS -->
    <div class="panel">
        <h2>Order · Table @Model.TableOrder.TableId</h2>

        @if (Model.OrderItems.Any())
        {
            var orderedItems = Model.OrderItems.Where(i => i.Status == Chapeau.Models.Enums.OrderItemStatus.Ordered).ToList();
            var readyItems = Model.OrderItems.Where(i => i.Status == Chapeau.Models.Enums.OrderItemStatus.Ready).ToList();
            var servedItems = Model.OrderItems.Where(i => i.Status == Chapeau.Models.Enums.OrderItemStatus.Served).ToList();

            @foreach (var orderItem in orderedItems)
            {
                <div class="order-row">
                    <div class="qty-ctrl">
                        <form asp-action="DecreaseItem" method="post">
                            <input type="hidden" name="orderItemId" value="@orderItem.OrderItemId" />
                            <input type="hidden" name="tableId" value="@Model.TableOrder.TableId" />
                            <button type="submit" class="btn-qty">−</button>
                        </form>
                        <span class="qty-num">@orderItem.Qty</span>
                        <form asp-action="AddItem" method="post">
                            <input type="hidden" name="MenuItemId" value="@orderItem.MenuItem.MenuItemId" />
                            <input type="hidden" name="tableId" value="@Model.TableOrder.TableId" />
                            <button type="submit" class="btn-qty">+</button>
                        </form>
                    </div>

                    <div class="order-item-info">
                        <span class="order-item-name">@orderItem.Name</span>
                        <form asp-action="UpdateItemNote" method="post" class="note-form">
                            <input type="hidden" name="orderItemId" value="@orderItem.OrderItemId" />
                            <input type="hidden" name="tableId" value="@Model.TableOrder.TableId" />
                            <input type="text" name="note" class="note-input" placeholder="Add note…" value="@orderItem.Note" />
                            <button type="submit" class="btn-note-save">Save</button>
                        </form>
                    </div>
                    <span class="order-item-price">€@((orderItem.Price * orderItem.Qty).ToString("0.00"))</span>

                    <form asp-action="DeleteItem" method="post">
                        <input type="hidden" name="orderItemId" value="@orderItem.OrderItemId" />
                        <input type="hidden" name="tableId" value="@Model.TableOrder.TableId" />
                        <button type="submit" class="btn-del">✕</button>
                    </form>
                </div>
            }

            @if (readyItems.Any())
            {
                <div class="status-label ready">✓ Ready to serve</div>
                @foreach (var item in readyItems)
                {
                    <div class="status-card ready">
                        <div>
                            <span class="status-card-name">@item.Qty× @item.Name</span>
                            @if (!string.IsNullOrEmpty(item.Note))
                            {
                                <div class="status-card-note">📝 @item.Note</div>
                            }
                        </div>
                        <form asp-action="ServeItem" method="post">
                            <input type="hidden" name="orderItemId" value="@item.OrderItemId" />
                            <input type="hidden" name="tableId" value="@Model.TableOrder.TableId" />
                            <button type="submit" class="btn-served">Served</button>
                        </form>
                    </div>
                }
            }

            @if (servedItems.Any())
            {
                <div class="status-label served">✓ Served</div>
                @foreach (var item in servedItems)
                {
                    <div class="status-card served">
                        <div>
                            <span class="status-card-name">@item.Qty× @item.Name</span>
                            @if (!string.IsNullOrEmpty(item.Note))
                            {
                                <div class="status-card-note">📝 @item.Note</div>
                            }
                        </div>
                        <span class="status-card-price">€@((item.Price * item.Qty).ToString("0.00"))</span>
                    </div>
                }
            }

            <div class="order-total">
                <span class="order-total-label">Total (@orderCount items)</span>
                <span class="order-total-amount">€@orderTotal.ToString("0.00")</span>
            </div>
        }
        else
        {
            <div class="order-empty">No items yet. Add from the menu.</div>
        }

        <div class="comment-box">
            <div class="comment-title">Add feedback</div>
            <form asp-action="AddComment" method="post">
                <input type="hidden" name="tableId" value="@Model.TableOrder.TableId" />
                <select name="type" class="comment-type">
                    <option value="Comment">Comment</option>
                    <option value="Complaint">Complaint</option>
                    <option value="Praise">Praise</option>
                </select>
                <textarea name="text" class="comment-text" rows="2" placeholder="Write feedback…"></textarea>
                <button type="submit" class="btn-comment">Save feedback</button>
            </form>
        </div>
    </div>

</div>
